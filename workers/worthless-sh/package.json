{
  "name": "worthless-sh-worker",
  "version": "0.0.1",
  "private": true,
  "description": "Cloudflare Worker at worthless.sh — serves install.sh to curl, redirects browsers to wless.io",
  "type": "module",
  "scripts": {
    "stage:install-sh": "cp ../../install.sh ./install.sh",
    "pretest": "npm run stage:install-sh",
    "pretest:watch": "npm run stage:install-sh",
    "predev": "npm run stage:install-sh",
    "predeploy": "npm run stage:install-sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.4.0",
    "vitest": "~4.1.5",
    "wrangler": "^4.85.0"
  }
}
