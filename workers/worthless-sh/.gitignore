# Staged copy of the canonical install.sh (kept at the repo root). The
# `stage:install-sh` npm script copies it in before any build step; the
# copy is generated, never source. Anchored so future `**/install.sh`
# fixtures elsewhere under this dir aren't silently ignored.
/install.sh

# Wrangler deploy artifacts
.wrangler/

# Node
node_modules/
