# Bare Ubuntu 22.04 (jammy) image — still the dominant LTS on prod/CI boxes.
# Catches any drift where install.sh silently assumes 24.04-era tooling.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        curl \
        tar \
    && rm -rf /var/lib/apt/lists/*

RUN ! command -v python3 \
    && ! command -v python \
    && ! command -v pipx \
    && ! command -v uv

WORKDIR /work
COPY install.sh /work/install.sh
COPY tests/install_fixtures/verify_install.sh /work/verify_install.sh
RUN chmod +x /work/install.sh /work/verify_install.sh

CMD ["/bin/sh", "-c", "sh /work/install.sh && sh /work/verify_install.sh"]
