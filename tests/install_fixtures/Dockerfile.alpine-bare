# Bare Alpine image — NO python3, NO uv. Uses musl libc (not glibc).
#
# EXPECTED TO FAIL today: python-build-standalone (what uv fetches) does not
# ship musl builds. Until PBS adds musl, uv on Alpine either refuses with
# "no compatible Python build" or downloads a glibc binary that segfaults.
# We keep this test in the matrix to surface a green day when PBS/uv ships
# musl support — that's the signal. Marked `experimental` so failures are
# non-blocking in CI.
FROM alpine:3.20

# install.sh needs:
#   curl + ca-certs (TLS)
#   bash  (install.sh is sh-compat but uv sub-shells prefer bash)
#   tar + zstd  (modern PBS tarballs are .tar.zst; busybox tar can't unzstd)
RUN apk add --no-cache \
        bash \
        ca-certificates \
        curl \
        tar \
        zstd

RUN ! command -v python3 \
    && ! command -v python \
    && ! command -v uv

WORKDIR /work
COPY install.sh /work/install.sh
COPY tests/install_fixtures/verify_install.sh /work/verify_install.sh
RUN chmod +x /work/install.sh /work/verify_install.sh

CMD ["/bin/sh", "-c", "sh /work/install.sh && sh /work/verify_install.sh"]
