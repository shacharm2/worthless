# Ubuntu 24.04 with uv pre-installed.
# Validates that install.sh reuses an existing uv rather than reinstalling.
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        coreutils \
        curl \
        tar \
    && rm -rf /var/lib/apt/lists/*

# Pre-install uv to $HOME/.local/bin (same place install.sh would put it).
RUN sh -c 'curl -LsSf https://astral.sh/uv/install.sh | sh' \
    && test -x "$HOME/.local/bin/uv"

# Sanity: uv present at expected path, python3 absent.
RUN ! command -v python3 \
    && test -x /root/.local/bin/uv

WORKDIR /work
COPY install.sh /work/install.sh
COPY tests/install_fixtures/verify_install.sh /work/verify_install.sh
RUN chmod +x /work/install.sh /work/verify_install.sh

# Hash uv before install, verify byte-identical after (proves reuse, not
# reinstall). Stronger than mtime: immune to `touch`, 1-second races, and
# same-content re-downloads that change the inode.
CMD ["/bin/sh", "-c", "UV_BEFORE=$(sha256sum /root/.local/bin/uv | cut -d' ' -f1) \
    && sh /work/install.sh \
    && UV_AFTER=$(sha256sum /root/.local/bin/uv | cut -d' ' -f1) \
    && [ \"$UV_BEFORE\" = \"$UV_AFTER\" ] || { echo 'FAIL: uv was reinstalled (hash changed)'; exit 1; } \
    && sh /work/verify_install.sh"]
