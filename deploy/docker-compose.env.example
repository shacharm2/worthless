# No secrets needed here. The container generates its own Fernet key on
# first boot. Volume separation (fernet key on /secrets, shard data on /data)
# is configured in docker-compose.yml via WORTHLESS_FERNET_KEY_PATH.
#
# Enroll keys via:
#   echo $YOUR_API_KEY | docker compose exec -T proxy worthless enroll \
#     --alias mykey --key-stdin --provider openai

# Optional tuning (defaults shown)
# WORTHLESS_ALLOW_INSECURE=true       # set if behind a TLS-terminating reverse proxy
# WORTHLESS_RATE_LIMIT_RPS=100
# WORTHLESS_UPSTREAM_TIMEOUT=120
# WORTHLESS_STREAMING_TIMEOUT=300
# WORTHLESS_MAX_REQUEST_BYTES=10485760
# WORTHLESS_ALLOW_ALIAS_INFERENCE=false
#
# Hot-path metering (Redis). Set to enable atomic spend-cap enforcement
# before key reconstruction. SQLite remains the durable ledger. Unset to
# fall back to SQLite-only metering (pre-Redis behaviour, no regression).
#
# When set, the redis service in docker-compose.yml refuses to start
# without REDIS_PASSWORD (see boot script). Both vars must be set
# together — the proxy authenticates to redis with the same password.
# Generate with: openssl rand -base64 48 | tr -d '/+=' | head -c64
# WORTHLESS_REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
# REDIS_PASSWORD=<generate-and-paste-here>
#
# When using TLS (recommended for any non-loopback deploy):
# WORTHLESS_REDIS_URL=rediss://:${REDIS_PASSWORD}@redis:6379/0
# WORTHLESS_REDIS_CA_PATH=/secrets/redis-ca.pem
# Operators bring their own CA; the cert SAN must include DNS:redis
# (the compose service name). Without a CA, plaintext redis:// over
# the internal `backend: internal: true` network is the documented
# v1.1 path — the network ACL is your defense in that mode.
